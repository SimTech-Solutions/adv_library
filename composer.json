{
  "name": "simtech/adv-library",
  "description": "PHP library for ADV insurance API processing with SOAP and REST endpoints",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "SIMTECH, LDA",
      "email": "simtek2022@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-xml": "*",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "phpstan/phpstan": "^1.10",
    "squizlabs/php_codesniffer": "^3.7",
    "mockery/mockery": "^1.5"
  },
  "autoload": {
    "psr-4": {
      "AdvClientAPI\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AdvClientAPI\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse src",
    "phpcs": "phpcs --standard=PSR12 src",
    "phpcs-fix": "phpcbf --standard=PSR12 src"
  }
}
